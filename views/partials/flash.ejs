 <% if (messages && messages.error && messages.error.length > 0) { %>
    <div class="bg-red-100 text-red-800 border border-red-300 px-4 py-2 rounded mb-4 text-sm">
      <%= messages.error %>
    </div>
  <% } %>

  <% if (messages && messages.success && messages.success.length > 0) { %>
    <div class="bg-green-100 text-green-800 border border-green-300 px-4 py-2 rounded mb-4 text-sm">
      <%- messages.success %>
    </div>
  <% } %>

