
<div class="min-h-screen bg-gray-50 pt-24 px-4 dark:bg-gray-800">
  <div class="max-w-md mx-auto bg-white p-8 rounded-2xl shadow-lg dark:bg-gray-900">
    <h1 class="text-xl font-bold text-blue-600 mb-4 text-center">Vérifier un numéro</h1>
 <!-- Flash messages -->
 <%- include('partials/flash') %>
    
    <form action="/check" method="POST" class="space-y-4">
      <input type="text" name="phone" placeholder="Entrer le numéro de téléphone" required
        class="w-full border rounded p-2 focus:outline-none focus:ring-2 focus:ring-blue-300 dark:text-gray-900">
      <button type="submit"
        class="w-full bg-blue-600 text-white p-2 rounded hover:bg-blue-700 transition">Vérifier</button>
    </form>
  </div>
</div>
