
<div class="min-h-screen bg-gray-50  md:flex-row dark:bg-gray-800">
     <div class="p-10">
    <h1 class="text-xl font-bold text-blue-600 mb-4 text-center">Détails de compte</h1>

<div class="max-w-4xl mx-auto mt-16 p-6 bg-white dark:bg-gray-700 rounded shadow flex flex-col md:flex-row gap-6">
   
    <!-- Profile Picture (40%) -->
     <div class="md:w-2/5 flex justify-center items-center">
        <!-- <form action="/update-profile-photo" method="POST" enctype="multipart/form-data"> -->
<!-- Image de profil principale -->
<div id="openModal" class="cursor-pointer">
  <img src="<%= user.profile_image ? '/uploads/' + user.profile_image : '/images/default.png' %>"
       class="rounded-full w-32 h-32 object-cover border border-gray-300"
       alt="Photo de profil">
</div>
      <input type="file" name="profile" id="file-upload" class="hidden" onchange="this.form.submit()">
            <div>
                <%- include('../partials/flash') %>
            </div> 
        <!-- </form> -->
      </div>
      <!-- Info Section (60%) -->
      <div class="md:w-3/5 space-y-4">
        <div>
          <label class="block text-gray-600 dark:text-gray-300 font-semibold">Vendeur</label>
          <p class="text-gray-800 dark:text-gray-100"><%= user.business_name %></p>
        </div>
  
        <div>
          <label class="block text-gray-600 dark:text-gray-300 font-semibold">Email</label>
          <a href="mailto:<%= user.email %>" class="text-blue-600 dark:text-blue-400 underline">
            <%= user.email %>
          </a>       
         </div>
  
        <div>
          <label class="block text-gray-600 dark:text-gray-300 font-semibold">Lien social</label>
          <% if (user.social_link) { 
            const fullLink = user.social_link.startsWith('http://') || user.social_link.startsWith('https://')
                             ? user.social_link 
                             : 'https://' + user.social_link;
       %>
         <a href="<%= fullLink %>" target="_blank" class="text-blue-600 dark:text-blue-400 underline break-words">
           <%= user.social_link %>
         </a>
       <% } else { %>
         <p class="text-gray-800 dark:text-gray-100">Non fourni</p>
       <% } %>
        </div>
  
        <div>
          <a href="/update-password" class="inline-block px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600">
            Mettre à jour le mot de passe
          </a>
        </div>
      </div>
    </div>
  </div>
  </div>
  
 <!-- Modale cachée par défaut -->
<div id="modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden">
  <div class="bg-white p-6 rounded-lg shadow-lg relative">
    <!-- Bouton de fermeture -->
    <button id="closeModal" class="absolute top-2 right-2 text-gray-500 hover:text-gray-700">
      &times;
    </button>
    <h2 class="text-l font-semibold mb-4">Changer la photo de profil</h2>
    <form action="/update-profile-photo" method="POST" enctype="multipart/form-data">
      <div class="flex flex-col items-center">
     <!-- Conteneur de l'image avec icône -->
      <div class="relative inline-block">
          <img src="<%= user.profile_image ? '/uploads/' + user.profile_image : '/images/default.png' %>"
               class="rounded-full w-32 h-32 object-cover mb-4"
               alt="Photo de profil">
         <!-- Icône de modification -->
         <label for="file-upload-modal" class="cursor-pointer">
         <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-white text-orange-400 p-2 rounded-full">
          <i class="fas fa-pen"></i>
         </div>
         </label>

        </div>
        <input type="file" name="profile" id="file-upload-modal" class="hidden" onchange="this.form.submit()">
       
      </div>
    </form>
  </div>
</div>

<script>
  document.getElementById('openModal').addEventListener('click', function(event) {
    event.preventDefault(); // Empêche tout comportement par défaut
    document.getElementById('modal').classList.remove('hidden');
  });

  document.getElementById('closeModal').addEventListener('click', function() {
    document.getElementById('modal').classList.add('hidden');
  });

  // Fermer la modale en cliquant à l'extérieur du contenu
  window.addEventListener('click', function(event) {
    const modal = document.getElementById('modal');
    if (event.target === modal) {
      modal.classList.add('hidden');
    }
  });
</script>
