<div class="min-h-screen p-6 bg-gray-50 pt-24">
    <div class="max-w-5xl mx-auto space-y-10">
  <h2 class="text-2xl font-bold mb-6 text-center">Gestion des raisons de blacklist</h2> 

  <!-- Flash messages -->
  <%- include('partials/flash') %>

  <!-- Add Reason Form -->
  <form method="POST" action="/admin/blacklist_reasons/add" class="mb-6 flex space-x-4">
    <input name="reason" type="text" placeholder="Nouvelle raison..." class="w-full border px-4 py-2 rounded" required>
    <button class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded">Ajouter</button>
  </form>

  <!-- Table of reasons -->
  <table class="w-full table-auto bg-white shadow-md rounded-lg">
    <thead class="bg-red-100 text-red-800 font-semibold">
      <tr>
        <th class="px-4 py-2 text-left">#</th>
        <th class="px-4 py-2 text-left">Raison</th>
        <th class="px-4 py-2 text-left">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% reasons.forEach((reason, index) => { %>
        <tr class="<%= index % 2 === 0 ? 'bg-orange-50' : 'bg-orange-100' %>">
          <td class="px-4 py-2"><%= reason.id %></td>
          <td class="px-4 py-2"><%= reason.reason %></td>
          <td class="px-4 py-2 flex gap-2">
            <!-- Edit Form -->
            <form method="POST" action="/admin/blacklist_reasons/update/<%= reason.id %>" class="flex gap-2">
              <input type="text" name="updatedReason" value="<%= reason.reason %>" class="border px-2 py-1 rounded" required>
              <button class="bg-blue-500 hover:bg-blue-600 text-white px-2 py-1 rounded">Modifier</button>
            </form>
            <!-- Delete Modal -->
                <button 
                class="bg-red-500 hover:bg-red-600 text-white px-2 py-1 rounded" 
                onclick="openDeleteReasonModal('<%= reason.id %>', '<%= reason.reason %>')">
                Supprimer
              </button>           
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<!-- Delete Reason Modal -->
<div id="deleteReasonModal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-lg w-96 p-6 text-center space-y-4">
      <h2 class="text-lg font-semibold text-red-600">Confirmer la suppression</h2>
      <p class="text-sm text-gray-700">Êtes-vous sûr de vouloir supprimer la raison suivante ?</p>
      <p class="text-lg font-bold text-gray-900" id="deleteReasonText"></p>
  
      <form id="deleteReasonForm" method="POST">
        <div class="flex justify-center space-x-4 pt-4">
          <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-md">
            Oui, supprimer
          </button>
          <button type="button" onclick="closeDeleteReasonModal()" class="bg-gray-300 hover:bg-gray-400 text-gray-800 px-4 py-2 rounded-md">
            Annuler
          </button>
        </div>
      </form>
    </div>
  </div>
  

</div>
</div>


  
