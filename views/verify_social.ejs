<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
    <div class="bg-white shadow-lg rounded-xl p-6 max-w-lg w-full text-center border border-blue-100">
     
        <h1 class="text-2xl font-bold text-blue-600 mb-4">Vérification de votre compte</h1>
      
      <p class="mb-3 text-gray-700">
        Pour vérifier votre identité, merci d’ajouter le code suivant dans votre <strong>bio</strong> de votre compte(public) Instagram ou TikTok, vous pouvez le supprimer une fois votre compte est vérifié :
      </p>
  
      <div class="bg-blue-50 text-blue-700 font-mono text-lg p-3 rounded-lg border border-blue-300 mb-4 inline-block">
        <%= code %>
      </div>
  
      <p class="text-gray-600 text-sm mb-6">
        Une fois ajouté, nous pourrons vérifier automatiquement que le compte vous appartient.
      </p>
      <form action="/verify-social-check" method="POST" class="mt-4">
        <input type="hidden" name="code" value="<%= code %>">
        <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition">
          Vérifier mon compte
        </button>
      </form>
       <!-- Flash messages -->
    </br> 
 <%- include('partials/flash') %>
      <a href="/login" class="text-blue-600 underline hover:text-blue-800">Se connecter</a>
    </div>
  </div>
  