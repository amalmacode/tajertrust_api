

<div class="min-h-screen p-6 bg-gray-50 pt-24">
    <div class="max-w-5xl mx-auto space-y-10">
  
      <h2 class="text-2xl font-bold mb-6 text-center">Sellers en cours de validation</h2> 
  <input type="text" id="searchPending" placeholder="Rechercher..." class="w-full mb-4 p-2 border rounded">
  <!-- Flash messages -->
  <%- include('partials/flash') %>

  <table class="w-full text-left border">
    <thead>
      <tr>
        <th class="p-2">Nom de business</th>
        <th>Email</th>
        <th>Vérifié ?</th>
        <th>Lien social</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody id="pendingTable">
      <% sellers.forEach(seller => { %>
        <tr class="border-t">
          <td class="p-2"><%= seller.business_name %></td>
          <td><%= seller.email %></td>
          <td class="text-center text-lg">
            <span class="<%= seller.is_verified ? 'text-green-600' : 'text-red-500' %>">
              <%= seller.is_verified ? '✅' : '❌' %>
            </span>
          </td>
          <td><a href="<%= seller.social_link %>" target="_blank" class="text-blue-600 underline">Voir</a></td>
          <td>
            <form method="POST" action="/admin/validate_seller/<%= seller.id %>?page=<%= currentPage %>">
              <input type="hidden" name="currentPage" value="<%= currentPage %>">
              <button class="bg-green-500 hover:bg-green-600 text-white px-2 py-1 rounded">Valider</button>
            </form>
            </td>
            <td>
              <button
                onclick="openDeleteModal('<%= seller.id %>', '<%= seller.business_name %>')"
                class="bg-red-700 hover:bg-red-800 text-white px-2 py-1 rounded">
                Supprimer
              </button>

            </td>
            
        </tr>
      <% }) %>
    </tbody>
  </table>

  
  <div class="flex justify-center mt-6 space-x-2">
    <% for (let i = 1; i <= totalPages; i++) { %>
      <a href="?page=<%= i %>"
         class="px-3 py-1 rounded border text-sm <%= i === currentPage ? 'bg-blue-600 text-white' : 'bg-white hover:bg-blue-100' %>">
        <%= i %>
      </a>
    <% } %>
  </div>
  

  <!-- Delete Seller Modal -->
<div id="deleteModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
  <div class="bg-white p-6 rounded shadow-lg w-96">
    <h2 class="text-xl font-bold mb-4">Supprimer le vendeur</h2>
    <p id="deleteBusinessName" class="mb-4"></p>
    <form id="deleteForm" method="POST" action="/admin/delete_seller">
      <input type="hidden" name="seller_id" id="deleteSellerId">
      <input type="hidden" name="currentPage" value="<%= currentPage %>">
      <label for="deleteReason" class="block mb-1">Raison de suppression :</label>
      <textarea name="reason" id="deleteReason" required class="w-full border rounded px-2 py-1 mb-4"></textarea>
      <div class="flex justify-end space-x-2">
        <button type="button" onclick="closeDeleteModal()" class="px-4 py-2 bg-gray-300 rounded">Annuler</button>
        <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded">Supprimer</button>
      </div>
    </form>
  </div>
</div>

</div>

</div>
