
<div class="min-h-screen p-6 bg-gray-50 pt-24">
    <div class="max-w-5xl mx-auto space-y-10">
  <h2 class="text-2xl font-bold mb-6 text-center">Sellers validés</h2> 

  <input type="text" id="searchValidated" placeholder="Rechercher..." class="w-full mb-4 p-2 border rounded">
  <!-- Flash messages -->
  <%- include('partials/flash') %>
  <table class="w-full text-left border">
    <thead>
      <tr>
        <th class="p-2">Nom de business</th>
        <th>Email</th>
        <th>Lien social</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody id="validatedTable">
      <% sellers.forEach(seller => { %>
        <tr class="border-t">
          <td class="p-2"><%= seller.business_name %></td>
          <td><%= seller.email %></td>
          <td><a href="<%= seller.social_link %>" target="_blank" class="text-blue-600 underline">Voir</a></td>
          <td>
            <button
              onclick="openDevalidateModal('<%= seller.id %>', '<%= seller.business_name %>','<%= currentPage %>')"
              class="bg-red-500 hover:bg-red-600 text-white px-2 py-1 rounded">
              Dévalider
            </button>
          </td>
                   
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div class="flex justify-center mt-6 space-x-2">
    <% for (let i = 1; i <= totalPages; i++) { %>
      <a href="?page=<%= i %>"
         class="px-3 py-1 rounded border text-sm <%= i === currentPage ? 'bg-blue-600 text-white' : 'bg-white hover:bg-blue-100' %>">
        <%= i %>
      </a>
    <% } %>
  </div>

  <!-- Devalidate Modal -->
<div id="devalidateModal" class="hidden fixed inset-0 z-50 bg-black bg-opacity-50 justify-center items-center">
    <div class="bg-white p-6 rounded shadow-lg w-full max-w-md">
      <h2 class="text-xl font-bold mb-4">Dévalider le vendeur : <span id="devalidateBusinessName"></span></h2>
      <form id="devalidateForm" method="POST" action="/admin/devalidate">
        <input id="devalidateCurrentPage" type="hidden" name="currentPage" value="<%= currentPage %>">
        <input type="hidden" name="seller_id" id="devalidateSellerId">
        <label class="block mb-2 text-sm font-medium"> Cause de dévalidation :</label>
        <textarea name="cause" required class="w-full border rounded p-2 mb-4" placeholder="Expliquez pourquoi..."></textarea>
        <div class="flex justify-end space-x-4">
          <button type="button" onclick="closeDevalidateModal()" class="px-4 py-2 bg-gray-300 rounded">Annuler</button>
          <button type="submit" class="px-4 py-2 bg-red-500 text-white rounded hover:bg-red-600">Dévalider</button>
        </div>
      </form>
    </div>
  </div>
  
</div>
</div>
