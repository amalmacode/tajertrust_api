    
<div class="min-h-screen p-6 bg-gray-50 pt-24">
    <div class="max-w-5xl mx-auto space-y-10">
      <h2 class="text-2xl font-bold mb-6 text-center">Gérer la FAQ</h2> 

        <%- include('partials/flash') %>
    <form method="POST" action="/admin/manage_faq/add" class="mb-6 space-y-2">
      <input type="text" name="question" placeholder="Question" required class="w-full border rounded p-2" />
      <textarea name="answer" placeholder="Réponse" required class="w-full border rounded p-2"></textarea>
      <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded">Ajouter</button>
    </form>

    <ul>
        <% faqs.forEach(faq => { %>
          <li class="border p-4 rounded mb-4">
            <form method="POST" action="/admin/manage_faq/edit/<%= faq.id %>" class="space-y-2">
              <input type="text" name="question" value="<%= faq.question %>" class="w-full p-2 border rounded" />
              <textarea name="answer" class="w-full p-2 border rounded"><%= faq.answer %></textarea>
              <!-- Buttons container -->
              <div class="flex space-x-2 mt-2">
                <button type="submit" class="bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-1 rounded">
                  Modifier
                </button>
              </form>
                <!-- Separate delete form -->
                <form method="POST" action="/admin/manage_faq/delete/<%= faq.id %>">
                  <button type="submit" class="bg-red-500 hover:bg-red-600 text-white px-4 py-1 rounded">
                    Supprimer
                  </button>
                </form>
              </div>
            <!-- </form> -->
          </li>
        <% }) %>
      </ul>
    
  </div>
  </div>
  