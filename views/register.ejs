<div class="min-h-screen bg-gray-50 flex flex-col md:flex-row">
  <!-- Left part (image + slogan + contactez-nous) -->
  <div class="hidden md:flex w-full md:w-3/5 bg-blue-200 items-center justify-center p-8">
    <div class="text-center max-w-md">
      <img src="/images/security.svg" alt="Sécurité" class="w-48 h-auto mx-auto mb-6">
      <h2 class="text-3xl font-bold text-blue-700 mb-4">Sécurisez votre business en toute confiance</h2>
      <p class="text-gray-600 mb-6">Notre plateforme vous aide à éviter les clients frauduleux et à protéger vos ventes.</p>
      <a href="/contact_admin" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition">Contactez-nous</a>
    </div>
  </div>

  <!-- Right part (formulaire d'inscription) -->
  <div class="dark:bg-gray-800 w-full md:w-2/5 bg-white flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <!-- Flash messages -->
      <%- include('partials/flash') %>

      <h1 class="text-xl font-bold text-blue-600 mb-4 text-center">Créer votre compte</h1>

      <!-- Instagram Business Registration Option -->
      <div class="mb-6">
        <button onclick="registerWithInstagramBusiness()" 
                class="w-full bg-gradient-to-r from-purple-500 to-pink-500 hover:from-purple-600 hover:to-pink-600 text-white font-semibold py-3 px-4 rounded-lg transition duration-200 flex items-center justify-center space-x-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          <span>S'inscrire avec Instagram Business</span>
        </button>
        <p class="text-xs text-gray-500 mt-2 text-center">
          Inscription rapide avec votre compte Instagram Business/Créateur
        </p>
      </div>

      <!-- Divider -->
      <div class="relative mb-6">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-300"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 bg-white text-gray-500 dark:bg-gray-800 dark:text-gray-400">ou</span>
        </div>
      </div>

      <!-- Traditional Email Registration Form -->
      <form action="/register" method="POST" class="space-y-4">
        <div>
          <label for="business_name" class="block text-sm font-medium text-gray-700 dark:text-gray-400">Nom de votre business</label>
          <input type="text" id="business_name" name="business_name" required
            class="mt-1 w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:text-gray-900">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-400">Email</label>
          <input type="email" name="email" required
            class="mt-1 w-full p-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-gray-900" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-400">Mot de passe</label>
          <input type="password" name="password" required
            class="mt-1 w-full p-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-gray-900" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-400">Confirmer le mot de passe</label>
          <input type="password" name="confirmPassword" required
            class="mt-1 w-full p-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-gray-900" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-400">
            Compte Instagram (@username ou lien complet) </label>
          <input type="text" name="social_link" required
            class="mt-1 w-full p-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-gray-900" />
          <p class="text-xs text-green-500 mt-1">
            Après votre inscription, vous serez invités à verifier que ce compte vous appartient.
          </p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-400">Website (Optionnel)</label>
          <input type="text" name="website"
            class="mt-1 w-full p-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 dark:text-gray-900" />
        </div>

        <button type="submit"
          class="w-full bg-blue-600 text-white rounded-md p-2 hover:bg-blue-700 transition-colors">S'inscrire</button>
      </form>

      <p class="mt-4 text-center text-sm text-gray-500">
        Vous avez déja un compte?
        <a href="/login" class="text-blue-600 hover:underline">Se connecter</a>
      </p>
    </div>
  </div>
</div>

<script>
function registerWithInstagramBusiness() {
  // Generate unique state for registration
  const state = 'register_instagram_' + Math.random().toString(36).substring(2, 15);
  
  // Your Instagram App ID (replace with your actual app ID)
  const clientId = '1512657023191128';
  
  // Detect if we're on localhost or production
  const isLocalhost = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
  const baseUrl = isLocalhost ? 'http://localhost:3000' : 'https://tajertrust.com';
  const redirectUri = encodeURIComponent(`${baseUrl}/auth/instagram/register-callback`);
  
  const scope = 'pages_show_list,instagram_basic,pages_manage_metadata';

  const instagramAuthUrl = `https://www.facebook.com/v21.0/dialog/oauth?client_id=${clientId}&redirect_uri=${redirectUri}&scope=${scope}&response_type=code&state=${state}`;
  
  // Redirect to Instagram OAuth for registration
  window.location.href = instagramAuthUrl;
}
</script>
