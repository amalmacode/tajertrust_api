<!-- views/admin_dashboard.ejs -->
<%- include('partials/header', { user: user }) %>
<!-- ********************* -->
<div class="min-h-screen p-6 bg-gray-50 pt-24">
  <div class="max-w-5xl mx-auto space-y-10">

    <h1 class="text-2xl font-bold text-center">📋 Dashboard Admin</h1>

    <!-- Table 1: Sellers pending validation -->
    <div class="bg-white p-6 rounded-xl shadow">
      <h2 class="text-xl font-semibold mb-4">🕐 En cours de validation</h2>
      <% if (pendingSellers.length === 0) { %>
        <p class="text-gray-500 text-sm">Aucun vendeur en attente.</p>
      <% } else { %>
      <table class="w-full text-sm text-left">
        <thead>
          <tr class="border-b">
            <th class="py-2">Nom de business</th>
            <th>Email</th>
            <th>Réseau social</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% pendingSellers.forEach(seller => { %>
            <tr class="border-t">
              <td class="py-2"><%= seller.name %></td>
              <td><%= seller.email %></td>
              <td><a href="<%= seller.social_link %>" target="_blank" class="text-blue-500 underline"><%= seller.social_link %></a></td>
              <td>
                <form action="/admin/validate/<%= seller.id %>" method="POST">
                  <button type="submit" class="px-3 py-1 bg-green-600 text-white rounded-md text-sm">Valider ✅</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

    <!-- Table 2: Validated sellers -->
    <div class="bg-white p-6 rounded-xl shadow">
      <h2 class="text-xl font-semibold mb-4">✅ Vendeurs validés</h2>
      <% if (validatedSellers.length === 0) { %>
        <p class="text-gray-500 text-sm">Aucun vendeur validé.</p>
      <% } else { %>
      <table class="w-full text-sm text-left">
        <thead>
          <tr class="border-b">
            <th class="py-2">Nom de Business</th>
            <th>Email</th>
            <th>Réseau social</th>
          </tr>
        </thead>
        <tbody>
          <% validatedSellers.forEach(seller => { %>
            <tr class="border-t">
              <td class="py-2"><%= seller.name %></td>
              <td><%= seller.email %></td>
              <td><a href="<%= seller.social_link %>" target="_blank" class="text-blue-500 underline"><%= seller.social_link %></a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

  </div>
</div>
