
  <div class="dark:bg-gray-900 min-h-screen bg-gray-50 pt-24 px-4">
  <div class=" dark:bg-gray-800 max-w-5xl mx-auto bg-white p-8 rounded-2xl shadow-lg">
<h1 class="text-2xl font-bold text-blue-600 mb-4 text-center">📱 Ma Blacklist</h1>

 <!-- Flash messages -->
 <%- include('partials/flash') %>
  <input type="text" id="searchInput" placeholder="Rechercher un numéro..." 
         class="dark:text-gray-900 w-full mb-4 px-3 py-2 border rounded shadow-sm" />

  <% if (entries.length === 0) { %>
    <p class="text-gray-600">Aucun numéro blacklisté pour le moment.</p>
  <% } else { %>
    <!-- <div class="space-y-4" id="blacklistContainer"> -->
      <div id="blacklistContainer" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% entries.forEach(entry => { %>
        <div class="dark:bg-gray-900  p-4 border rounded-2xl shadow-md bg-white">
            <table class="w-full text-sm text-left text-gray-400">
              <tbody>
                <tr class="border-b">
                  <td class="font-semibold py-2 w-32">📱 Numéro :</td>
                  <td class="py-2"><%= entry.phone %></td>
                </tr>
                <tr class="border-b">
                  <td class="font-semibold py-2">📌 Raison :</td>
                  <td class="py-2"><%= entry.reason %></td>
                </tr>
                <tr class="border-b">
                  <td class="font-semibold py-2">🗓️ Date :</td>
                  <td class="py-2"><%= entry.date %></td>
                </tr>
                <tr>
                  <td colspan="2" class="pt-3">
                    <div class="flex justify-end space-x-2">
                      <button class="bg-yellow-400 hover:bg-yellow-500 text-white px-4 py-1.5 rounded-md text-sm"
                              onclick="openEditModal('<%= entry.id %>', '<%= entry.phone %>', '<%= entry.reason %>')">
                        ✏️ Modifier
                      </button>
                      <button class="bg-red-500 hover:bg-red-600 text-white px-4 py-1.5 rounded-md text-sm"
                              onclick="openDeletePhoneModal('<%= entry.id %>', '<%= entry.phone %>')">
                        🗑️ Supprimer
                      </button>
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          
      <% }); %>
    </div>
  <% } %>
</div>

<!-- Update Modal -->
<div id="editModal" class=" fixed inset-0 bg-black bg-opacity-50 hidden justify-center items-center z-50">
  <div class="dark:bg-gray-800 bg-white p-6 rounded shadow-md w-full max-w-md">
    <h2 class="text-xl mb-4 font-bold">Modifier</h2>
    <form id="editForm" method="POST" action="/blacklist/update">
      <input type="hidden" name="id" id="editId" />
      <div class="mb-3">
        <label>Numéro :</label>
        <input type="text" name="phone" id="editPhone" class="dark:text-gray-900 w-full border px-3 py-2 rounded" required />
      </div>
      <div class="mb-3">
        <label>Raison :</label>
        <select name="reason" id="editReason" class="dark:text-gray-900 w-full border px-3 py-2 rounded">
          <option value="Rejete les appels de livreurs">Rejete les appels de livreurs</option>
          <option value="Refus fréquent de colis">Refus fréquent de colis</option>
          <option value="Numéro Escroc">Numéro Escroc</option>
          <option value="Autre">Autre</option>
        </select>
      </div>
      <div class="flex justify-end space-x-2">
        <button type="button" onclick="closeEditModal()" class="px-4 py-2 bg-gray-300 rounded">Annuler</button>
        <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded">Mettre à jour</button>
      </div>
    </form>
  </div>
</div>
<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-lg w-96 p-6 text-center space-y-4">
      <h2 class="text-lg font-semibold text-red-600">Confirmer la suppression</h2>
      <p class="text-sm text-gray-700">Êtes-vous sûr de vouloir supprimer le numéro suivant ?</p>
      <p class="text-lg font-bold text-gray-900" id="deletePhone"></p>
      <div class="flex justify-center space-x-4 pt-4">
        <form id="deleteForm" method="POST">
        <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-md">
          Oui, supprimer
        </button>
      </form>
        <button onclick="closeDeletePhoneModal()" class="bg-gray-300 hover:bg-gray-400 text-gray-800 px-4 py-2 rounded-md">
          Annuler
        </button>
      </div>
    </div>
  </div>
    
  </div>
  </div>
