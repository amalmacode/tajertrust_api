  <div class="dark:bg-gray-800 min-h-screen p-6 bg-gray-50 pt-24">
    <div class="max-w-5xl mx-auto space-y-10">
      <h1 class="text-xl font-bold text-blue-900 mb-4 text-center">Foire Aux Questions (FAQ)</h1>

      <% if (faqs.length === 0) { %>
        <p class="text-gray-600 text-center">Aucune question pour le moment.</p>
      <% } %>
  
      <ul id="faq-list" class="space-y-4 ">
        <% faqs.forEach((faq, index) => { %>
          <li class="bg-white shadow p-4 rounded">
            <button type="button" 
                    class="faq-toggle flex justify-between items-center w-full font-semibold text-lg text-blue-700">
              <span><%= faq.question %></span>
              <span class="faq-icon">+</span>
            </button>
            <p class="faq-answer text-gray-700 mt-2 hidden"><%= faq.answer %></p>
          </li>
        <% }) %>
      </ul>
    </div>
  </div>
  
