<div class="min-h-screen bg-gray-50 py-12 px-4">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">
      Sélectionnez votre Page Facebook
    </h2>
    <p class="text-gray-600 text-center mb-8">
      Choisissez la page Facebook avec le compte Instagram que vous souhaitez utiliser
    </p>

    <%- include('partials/flash') %>

    <div class="space-y-4">
      <% pages.forEach(page => { %>
      <div class="bg-white border-2 border-gray-200 rounded-lg p-6 hover:border-blue-500 transition cursor-pointer"
           onclick="selectPage('<%= page.page_id %>', '<%= page.instagram_id %>', '<%= page.instagram_username %>')">
        
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">
              📄 <%= page.page_name %>
            </h3>
            <p class="text-gray-600">
              📷 Instagram: <strong>@<%= page.instagram_username %></strong>
            </p>
            <p class="text-sm text-gray-500 mt-1">
              Instagram Account ID: <%= page.instagram_id %>
            </p>
          </div>
          <button class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700">
            Sélectionner
          </button>
        </div>
      </div>
      <% }) %>
    </div>

    <% if (pages.length === 0) { %>
    <div class="text-center py-8">
      <p class="text-gray-600">Aucune page Facebook avec compte Instagram trouvée.</p>
      <a href="/register" class="text-blue-600 mt-4 inline-block">Retour à l'inscription</a>
    </div>
    <% } %>
  </div>
</div>

<form id="pageSelectionForm" method="POST" action="/select-facebook-page" style="display: none;">
  <input type="hidden" name="page_id" id="selected_page_id">
  <input type="hidden" name="instagram_id" id="selected_instagram_id">
  <input type="hidden" name="instagram_username" id="selected_instagram_username">
</form>

<script>
function selectPage(pageId, instagramId, instagramUsername) {
  document.getElementById('selected_page_id').value = pageId;
  document.getElementById('selected_instagram_id').value = instagramId;
  document.getElementById('selected_instagram_username').value = instagramUsername;
  document.getElementById('pageSelectionForm').submit();
}
</script>