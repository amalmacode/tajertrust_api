<div class="min-h-screen bg-gray-100 flex flex-col md:flex-row">

  <!-- Partie gauche (image + message) -->
  <div class="hidden md:flex w-full md:w-3/5 bg-blue-100 items-center justify-center p-8">
    <div class="text-center max-w-md">
      <img src="/images/security.png" alt="Sécurité" class="w-48 h-auto mx-auto mb-6">
      <h2 class="text-3xl font-bold text-blue-700 mb-4">Restez serein</h2>
      <p class="text-gray-600 mb-6">Créez un nouveau mot de passe fort pour protéger votre compte.</p>
      <a href="/contact" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition">Contactez-nous</a>
    </div>
  </div>

  <!-- Partie droite (code d’origine) -->
    <div class="w-full md:w-2/5 bg-white flex items-center justify-center px-4 py-12">
    <div class="bg-white p-8 rounded-lg shadow-md w-full max-w-md">
      <h1 class="text-2xl font-bold text-blue-600 mb-6 text-center">🔐 Réinitialiser le mot de passe</h1>
      <!-- Flash message if token is invalid or expired -->
      <%- include('partials/flash') %>

      <form action="/reset-password/<%= token %>" method="POST" class="space-y-4">
        <!-- Nouveau mot de passe -->
        <div>
          <label for="password" class="block text-sm font-medium text-gray-700">Nouveau mot de passe</label>
          <input type="password" id="password" name="password" required
                 class="mt-1 w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-300" />
        </div>
        <!-- Confirmer le mot de passe -->
        <div>
          <label for="confirm_password" class="block text-sm font-medium text-gray-700">Confirmer le mot de passe</label>
          <input type="password" id="confirm_password" name="confirm_password" required
                 class="mt-1 w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-300" />
        </div>

        <!-- Bouton -->
        <button type="submit"
                class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-200">
          Réinitialiser
        </button>
      </form>
    </div>
  </div>
</div>
