<!-- views/verify-social.ejs -->
<div class="verification-container">
    <div class="verification-header">
        <h1>🛡️ Vérification de votre compte social</h1>
        <p class="subtitle">Dernière étape avant l'activation de votre compte</p>
    </div>

    <!-- Messages -->
    <% if (messages.error && messages.error.length > 0) { %>
        <div class="alert alert-danger">
            <% messages.error.forEach(function(error) { %>
                <p><%= error %></p>
            <% }); %>
        </div>
    <% } %>

    <% if (messages.success && messages.success.length > 0) { %>
        <div class="alert alert-success">
            <% messages.success.forEach(function(success) { %>
                <p><%= success %></p>
            <% }); %>
        </div>
    <% } %>

    <!-- Progress Steps -->
    <div class="progress-steps">
        <div class="step completed">
            <div class="step-number">1</div>
            <div class="step-label">Inscription</div>
        </div>
        <div class="step active">
            <div class="step-number">2</div>
            <div class="step-label">Vérification Social</div>
        </div>
        <div class="step">
            <div class="step-number">3</div>
            <div class="step-label">Email</div>
        </div>
        <div class="step">
            <div class="step-number">4</div>
            <div class="step-label">Validation Admin</div>
        </div>
    </div>

    <!-- Seller Info -->
    <div class="seller-info-card">
        <h3>👋 Bonjour <%= seller.business_name %>!</h3>
        <p>Votre inscription est presque terminée. Vérifiez votre compte social pour continuer.</p>
        
        <div class="social-link-display">
            <strong>Compte social déclaré:</strong>
            <a href="<%= seller.social_link %>" target="_blank" class="social-link">
                <%= seller.social_link %>
            </a>
        </div>
    </div>

    <!-- Verification Status -->
    <% if (seller.is_social_verified) { %>
        <!-- Already Verified -->
        <div class="verification-success">
            <div class="success-icon">✅</div>
            <h3>Compte Instagram vérifié!</h3>
            <p><strong>@<%= seller.instagram_username %></strong></p>
            <p>Type: <%= seller.instagram_account_type %></p>
            <% if (seller.instagram_followers_count) { %>
                <p>Abonnés: <%= seller.instagram_followers_count.toLocaleString() %></p>
            <% } %>
            <p class="next-step">
                ✉️ <strong>Prochaine étape:</strong> Vérifiez votre email (<%= seller.email %>) pour confirmer votre inscription.
            </p>
            <a href="/login" class="btn btn-primary">Continuer vers la connexion</a>
        </div>
    <% } else { %>
        <!-- Need Verification -->
        <div class="verification-required">
            <% if (isInstagram) { %>
                <!-- Instagram Verification -->
                <div class="instagram-verification">
                    <div class="platform-icon">📷</div>
                    <h3>Vérification Instagram Business</h3>
                    <p>Confirmez que vous êtes le propriétaire de ce compte Instagram Business pour renforcer la confiance des clients.</p>
                      <!-- DEBUT DEMO -->
                       <!-- Ajoutez cette section dans votre verify-social.ejs, juste avant les boutons normaux -->

<% if (isInstagram && !seller.is_social_verified) { %>
    <!-- Section spéciale pour Facebook Reviewers -->
    <div class="facebook-reviewers-section" style="background: linear-gradient(135deg, #1877f2, #42a5f5); color: white; padding: 25px; border-radius: 12px; margin: 30px 0; text-align: center;">
        <h3>🔍 FOR FACEBOOK APP REVIEWERS</h3>
        <p><strong>Special Demo Mode Available</strong></p>
        <p>Click below to see a complete demonstration of Instagram verification with simulated success (shows what would happen with instagram_business_basic permission)</p>
        
        <div style="margin: 20px 0;">
            <a href="/demo-oauth-page?code=<%= code %>" class="btn" style="background: white; color: #1877f2; padding: 15px 30px; border-radius: 25px; text-decoration: none; font-weight: bold; margin: 10px;">
                🎬 DEMO: Complete Instagram Verification Flow
            </a>
        </div>
        
        <div style="background: rgba(255,255,255,0.1); padding: 15px; border-radius: 8px; margin-top: 15px;">
            <p><strong>This demo shows:</strong></p>
            <ul style="text-align: left; margin: 10px 0;">
                <li>✅ Successful Facebook OAuth authorization</li>
                <li>✅ Instagram username and ID fetching (simulated)</li>
                <li>✅ Account ownership confirmation</li>
                <li>✅ Verified badge creation</li>
                <li>✅ Complete user experience with permission granted</li>
            </ul>
        </div>
        
        <p style="font-size: 14px; margin-top: 15px;">
            <strong>Note:</strong> This demonstrates exactly what would happen if instagram_business_basic permission was approved.
        </p>
    </div>
    
    <!-- Séparateur -->
    <div style="text-align: center; margin: 30px 0;">
        <hr style="width: 50%; opacity: 0.3;">
        <p style="color: #666; margin: 20px 0;"><strong>Regular User Flow (Currently Shows Permission Error)</strong></p>
    </div>
<% } %>

                    <!-- FIN DEMO -->
                    <div class="verification-actions">
                        <a href="/auth/instagram/verify?code=<%= code %>" class="btn btn-instagram">
                            📷 Vérifier mon Instagram Business
                        </a>
                        
                        <form action="/skip-social-verification" method="POST" style="margin-top: 15px;">
                            <input type="hidden" name="code" value="<%= code %>">
                            <button type="submit" class="btn btn-link" onclick="return confirm('Êtes-vous sûr de vouloir ignorer la vérification? Cela réduira votre crédibilité.')">
                                Ignorer pour l'instant
                            </button>
                        </form>
                    </div>
                    <div class="verification-benefits">
                        <h4>🛡️ Avantages de la vérification:</h4>
                        <ul>
                            <li>✅ Badge de confiance sur votre profil</li>
                            <li>✅ Protection contre les faux comptes</li>
                            <li>✅ Priorité dans les recherches</li>
                            <li>✅ Accès aux fonctionnalités premium</li>
                        </ul>
                    </div>

                    <div class="verification-requirements">
                        <h4>📋 Prérequis:</h4>
                        <ul>
                            <li>Compte Instagram Business ou Créateur</li>
                            <li>Connecté à une page Facebook</li>
                            <li>Accès administrateur à cette page</li>
                        </ul>
                    </div>

                </div>
            <% } else if (isTikTok) { %>
                <!-- TikTok - Coming Soon -->
                <div class="tiktok-verification">
                    <div class="platform-icon">🎵</div>
                    <h3>Vérification TikTok</h3>
                    <p>La vérification TikTok sera bientôt disponible. Pour l'instant, vous pouvez continuer sans vérification.</p>
                    
                    <div class="coming-soon">
                        <p>🚧 <strong>Bientôt disponible:</strong> Vérification automatique des comptes TikTok Business</p>
                    </div>

                    <form action="/skip-social-verification" method="POST">
                        <input type="hidden" name="code" value="<%= code %>">
                        <button type="submit" class="btn btn-primary">
                            Continuer sans vérification TikTok
                        </button>
                    </form>
                </div>
            <% } else { %>
                <!-- Other platforms -->
                <div class="other-verification">
                    <div class="platform-icon">🔗</div>
                    <h3>Vérification du lien social</h3>
                    <p>Votre lien social a été enregistré. La vérification automatique n'est pas encore disponible pour cette plateforme.</p>
                    
                    <form action="/skip-social-verification" method="POST">
                        <input type="hidden" name="code" value="<%= code %>">
                        <button type="submit" class="btn btn-primary">
                            Continuer vers la vérification email
                        </button>
                    </form>
                </div>
            <% } %>
        </div>
    <% } %>

    <!-- Help Section -->
    <div class="help-section">
        <h4>❓ Besoin d'aide?</h4>
        <details>
            <summary>Mon Instagram n'est pas un compte Business</summary>
            <p>Pour convertir votre compte en Business:</p>
            <ol>
                <li>Ouvrez Instagram → Profil → Menu (3 lignes)</li>
                <li>Paramètres → Compte → Passer au compte professionnel</li>
                <li>Choisissez "Business" et connectez à votre page Facebook</li>
            </ol>
        </details>
        
        <details>
            <summary>Je n'ai pas de page Facebook</summary>
            <p>Créez une page Facebook:</p>
            <ol>
                <li>Allez sur <a href="https://facebook.com/pages/create" target="_blank">facebook.com/pages/create</a></li>
                <li>Créez une page pour votre business</li>
                <li>Connectez-la à votre Instagram dans les paramètres Instagram</li>
            </ol>
        </details>
        
        <details>
            <summary>La vérification échoue</summary>
            <p>Vérifiez que:</p>
            <ul>
                <li>Vous êtes admin de la page Facebook</li>
                <li>L'Instagram est bien connecté à cette page</li>
                <li>Votre compte est public ou Business</li>
            </ul>
        </details>
    </div>
</div>

<style>
/* Add to your existing CSS */
.verification-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 20px;
}

.verification-header {
    text-align: center;
    margin-bottom: 30px;
}

.verification-header h1 {
    color: #2c3e50;
    margin-bottom: 10px;
}

.subtitle {
    color: #7f8c8d;
    font-size: 16px;
}

.progress-steps {
    display: flex;
    justify-content: center;
    margin: 30px 0;
    flex-wrap: wrap;
}

.step {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 0 15px;
    position: relative;
}

.step:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 15px;
    left: 50px;
    width: 30px;
    height: 2px;
    background: #ddd;
}

.step.completed .step-number {
    background: #27ae60;
    color: white;
}

.step.active .step-number {
    background: #3498db;
    color: white;
}

.step-number {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: #ddd;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    margin-bottom: 5px;
}

.step-label {
    font-size: 12px;
    text-align: center;
}

.seller-info-card {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 8px;
    margin: 20px 0;
    border-left: 4px solid #3498db;
}

.social-link-display {
    margin-top: 15px;
    padding: 10px;
    background: white;
    border-radius: 5px;
}

.social-link {
    color: #e74c3c;
    text-decoration: none;
    font-weight: bold;
}

.verification-success {
    background: #d1ecf1;
    padding: 30px;
    border-radius: 12px;
    text-align: center;
    border-left: 4px solid #17a2b8;
}

.success-icon {
    font-size: 60px;
    margin-bottom: 20px;
}

.verification-required {
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 12px;
    padding: 30px;
    margin: 20px 0;
}

.platform-icon {
    font-size: 50px;
    text-align: center;
    margin-bottom: 20px;
}

.verification-benefits,
.verification-requirements {
    background: #f8f9fa;
    padding: 15px;
    border-radius: 8px;
    margin: 15px 0;
}

.verification-benefits ul,
.verification-requirements ul {
    margin: 10px 0;
    padding-left: 20px;
}

.verification-actions {
    text-align: center;
    margin-top: 25px;
}

.btn {
    padding: 12px 25px;
    border-radius: 5px;
    text-decoration: none;
    font-weight: bold;
    display: inline-block;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
}

.btn-instagram {
    background: linear-gradient(45deg, #f09433 0%,#e6683c 25%,#dc2743 50%,#cc2366 75%,#bc1888 100%);
    color: white;
}

.btn-instagram:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
}

.btn-primary {
    background: #3498db;
    color: white;
}

.btn-link {
    background: none;
    color: #7f8c8d;
    text-decoration: underline;
}

.coming-soon {
    background: #fff3cd;
    padding: 15px;
    border-radius: 8px;
    margin: 15px 0;
    border-left: 4px solid #ffc107;
}

.help-section {
    margin-top: 40px;
    padding: 20px;
    background: #f8f9fa;
    border-radius: 8px;
}

.help-section details {
    margin: 10px 0;
    padding: 10px;
    background: white;
    border-radius: 5px;
}

.help-section summary {
    cursor: pointer;
    font-weight: bold;
    color: #3498db;
}

.help-section ol,
.help-section ul {
    margin: 10px 0;
    padding-left: 20px;
}

.next-step {
    background: #fff3cd;
    padding: 15px;
    border-radius: 8px;
    margin: 15px 0;
}

@media (max-width: 768px) {
    .progress-steps {
        flex-direction: column;
        align-items: center;
    }
    
    .step {
        margin: 10px 0;
    }
    
    .step:not(:last-child)::after {
        display: none;
    }
}
</style>